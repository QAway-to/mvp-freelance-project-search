# Next.js service — URL to reach Python service (inside Docker network)
PYTHON_API_URL=http://python-service:8000

# For local development (Python service running directly, not via Docker)
# PYTHON_API_URL=http://localhost:8000

# Python service settings
KWORK_BASE_URL=https://kwork.ru
KWORK_RATE_LIMIT_RPS=1
REQUEST_TIMEOUT=15
LOG_LEVEL=INFO

# Optional: Kwork session cookie for gated content (do NOT commit real value)
# Get from browser DevTools → Application → Cookies → kwork.ru → __utmz or similar
# KWORK_COOKIE=your_session_cookie_value_here

# Kwork credentials (for full mode)
KWORK_EMAIL=your_email@kwork.ru
KWORK_PASSWORD=your_password

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHANNEL_ID=@your_channel_username

# n8n Integration
N8N_WEBHOOK_URL=https://your-n8n-instance.com/webhook/freelance-project

# App settings
MODE=demo  # demo or full
LOG_LEVEL=INFO

# Search settings
# Multiple keywords supported (comma-separated)
SEARCH_KEYWORDS=бот, обработка данных, данные
# Legacy support (single keyword):
# SEARCH_KEYWORD=бот
MAX_PROJECTS_PER_SESSION=5
EVALUATION_THRESHOLD=0.4  # 40% relevance threshold

# Timing (seconds)
SESSION_DURATION_MAX=300  # 5 minutes max per session
PAUSE_BETWEEN_CHECKS=3600  # 1 hour between checks
READING_TIME_MIN=10
READING_TIME_MAX=30
